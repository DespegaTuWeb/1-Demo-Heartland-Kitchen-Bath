---
---
<section id="services" class="pb-20 md:pb-28 bg-[#fbfbfa] text-[#1c1c1a]">
  <div class="max-w-7xl mx-auto px-6">
    
    <!-- Section Header -->
    <div class="max-w-3xl flex flex-col space-y-3.5 mb-6">
      <span class="tracking-widest text-xs font-semibold text-[#b38f4f] uppercase block">
        Our Focus Areas
      </span>
      <h2 class="font-serif text-3xl sm:text-4xl md:text-5xl font-bold text-[#1c1c1a]">
        Simple Solutions for Your Entire Home
      </h2>
      <p class="text-[#1c1c1a] font-sans text-base leading-relaxed font-medium max-w-xl">
        We focus strictly on the three areas that make the biggest difference in your daily living space and home value.
      </p>
    </div>

    <!-- Encapsulated Services Grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 lg:gap-10">
      
      <!-- Card 1: Kitchen Remodeling -->
      <div class="bg-white border border-stone-200/80 p-8 rounded-lg shadow-sm flex flex-col group">
        <!-- Vertically contained photo inside card -->
        <div class="hover-zoom aspect-[4/3] w-full rounded-md overflow-hidden bg-stone-100 mb-6 border border-stone-200/40">
          <img 
            src="/images/service_kitchen.png" 
            alt="Remodeled bright kitchen with custom cabinets" 
            class="w-full h-full object-cover object-center grayscale-[10%] group-hover:grayscale-0"
          />
        </div>
        <div class="flex flex-col space-y-3.5">
          <!-- Accent Checkmark -->
          <div class="flex items-center space-x-2 text-[#b38f4f]">
            <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"></path>
            </svg>
            <span class="text-[10px] uppercase tracking-wider font-bold">Kitchens</span>
          </div>
          <h3 class="font-serif text-xl font-bold text-[#1c1c1a] group-hover:text-[#b38f4f] transition-colors duration-300">
            Kitchen Remodeling
          </h3>
          <p class="text-[#1c1c1a] font-sans text-base leading-relaxed font-medium max-w-md">
            Custom cabinets, quartz countertops, and open layouts designed to make cooking and gathering a pleasure.
          </p>
        </div>
      </div>

      <!-- Card 2: Bathroom Remodeling -->
      <div class="bg-white border border-stone-200/80 p-8 rounded-lg shadow-sm flex flex-col group">
        <!-- Vertically contained photo inside card -->
        <div class="hover-zoom aspect-[4/3] w-full rounded-md overflow-hidden bg-stone-100 mb-6 border border-stone-200/40">
          <img 
            src="/images/service_bathroom.png" 
            alt="Spa-like bathroom vanity and walk-in shower" 
            class="w-full h-full object-cover object-center grayscale-[10%] group-hover:grayscale-0"
          />
        </div>
        <div class="flex flex-col space-y-3.5">
          <!-- Accent Checkmark -->
          <div class="flex items-center space-x-2 text-[#b38f4f]">
            <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"></path>
            </svg>
            <span class="text-[10px] uppercase tracking-wider font-bold">Bathrooms</span>
          </div>
          <h3 class="font-serif text-xl font-bold text-[#1c1c1a] group-hover:text-[#b38f4f] transition-colors duration-300">
            Bathroom Remodeling
          </h3>
          <p class="text-[#1c1c1a] font-sans text-base leading-relaxed font-medium max-w-md">
            Walk-in showers, modern vanities, and premium tiling that turn cramped bathrooms into peaceful spaces.
          </p>
        </div>
      </div>

      <!-- Card 3: Basement Finishing -->
      <div class="bg-white border border-stone-200/80 p-8 rounded-lg shadow-sm flex flex-col group">
        <!-- Vertically contained photo inside card -->
        <div class="hover-zoom aspect-[4/3] w-full rounded-md overflow-hidden bg-stone-100 mb-6 border border-stone-200/40">
          <img 
            src="/images/service_basement.png" 
            alt="Finished basement family room" 
            class="w-full h-full object-cover object-center grayscale-[10%] group-hover:grayscale-0"
          />
        </div>
        <div class="flex flex-col space-y-3.5">
          <!-- Accent Checkmark -->
          <div class="flex items-center space-x-2 text-[#b38f4f]">
            <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"></path>
            </svg>
            <span class="text-[10px] uppercase tracking-wider font-bold">Basements</span>
          </div>
          <h3 class="font-serif text-xl font-bold text-[#1c1c1a] group-hover:text-[#b38f4f] transition-colors duration-300">
            Basement Finishing
          </h3>
          <p class="text-[#1c1c1a] font-sans text-base leading-relaxed font-medium max-w-md">
            Turning open lower levels into comfortable family rooms, guest suites, or organized play areas.
          </p>
        </div>
      </div>

    </div>
  </div>
</section>
