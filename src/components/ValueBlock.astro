---
---
<section id="guarantee" class="pt-10 pb-20 md:pt-10 md:pb-28 bg-[#fbfbfa] text-[#1c1c1a]">
  <div class="max-w-7xl mx-auto px-6">
    
    <!-- Title Section -->
    <div class="max-w-3xl flex flex-col space-y-3.5 mb-6">
      <span class="tracking-widest text-xs font-semibold text-[#b38f4f] uppercase block">
        Our Process
      </span>
      <h2 class="font-serif text-3xl sm:text-4xl md:text-5xl font-bold text-[#1c1c1a]">
        Our Guarantee: A Remodeling Process With Zero Stress
      </h2>
      <p class="text-[#1c1c1a] font-sans text-base leading-relaxed font-medium max-w-xl">
        We know the biggest worries with remodeling are unexpected costs, endless delays, and mess. Here is exactly how we eliminate those worries:
      </p>
    </div>

    <!-- 3-Column anxiety-reducing sequence grid (Compact layout on mobile, standard on desktop) -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      
      <!-- Card 01 -->
      <div class="bg-white border border-stone-200/80 p-5 md:p-8 rounded-lg shadow-sm flex flex-col group">
        <!-- Image Container -->
        <div class="hover-zoom aspect-[4/3] w-full rounded-md overflow-hidden bg-stone-100 mb-6 border border-stone-200/40">
          <img 
            src="/images/process_3d.png" 
            alt="3D Kitchen design blueprint mockup" 
            class="w-full h-full object-cover object-center grayscale-[10%] group-hover:grayscale-0 transition-all duration-300"
          />
        </div>
        <!-- Content Block -->
        <div class="flex flex-col items-start space-y-2">
          <div class="flex items-center space-x-2">
            <span class="text-lg md:text-xl font-serif font-bold text-[#b38f4f] group-hover:text-[#1c1c1a] transition-colors duration-300 leading-none shrink-0">01</span>
            <span class="w-4 h-[2px] bg-[#b38f4f] group-hover:bg-[#1c1c1a] transition-colors duration-300 shrink-0"></span>
            <h3 class="font-serif text-lg md:text-xl font-bold text-[#b38f4f] group-hover:text-[#1c1c1a] transition-colors duration-300 leading-none">
              See It in 3D First
            </h3>
          </div>
          <p class="text-[#1c1c1a] font-sans text-base leading-relaxed font-medium">
            We map out your entire project in 3D before buying materials.
          </p>
        </div>
      </div>

      <!-- Card 02 -->
      <div class="bg-white border border-stone-200/80 p-5 md:p-8 rounded-lg shadow-sm flex flex-col group">
        <!-- Image Container -->
        <div class="hover-zoom aspect-[4/3] w-full rounded-md overflow-hidden bg-stone-100 mb-6 border border-stone-200/40">
          <img 
            src="/images/process_time.png" 
            alt="Project calendar scheduler notebook and checklist" 
            class="w-full h-full object-cover object-center grayscale-[10%] group-hover:grayscale-0 transition-all duration-300"
          />
        </div>
        <!-- Content Block -->
        <div class="flex flex-col items-start space-y-2">
          <div class="flex items-center space-x-2">
            <span class="text-lg md:text-xl font-serif font-bold text-[#b38f4f] group-hover:text-[#1c1c1a] transition-colors duration-300 leading-none shrink-0">02</span>
            <span class="w-4 h-[2px] bg-[#b38f4f] group-hover:bg-[#1c1c1a] transition-colors duration-300 shrink-0"></span>
            <h3 class="font-serif text-lg md:text-xl font-bold text-[#b38f4f] group-hover:text-[#1c1c1a] transition-colors duration-300 leading-none">
              Done On Time
            </h3>
          </div>
          <p class="text-[#1c1c1a] font-sans text-base leading-relaxed font-medium">
            We give you a clear start and finish date in writing.
          </p>
        </div>
      </div>

      <!-- Card 03 -->
      <div class="bg-white border border-stone-200/80 p-5 md:p-8 rounded-lg shadow-sm flex flex-col group">
        <!-- Image Container -->
        <div class="hover-zoom aspect-[4/3] w-full rounded-md overflow-hidden bg-stone-100 mb-6 border border-stone-200/40">
          <img 
            src="/images/process_clean.png" 
            alt="Spotless modern kitchen after daily clean-up" 
            class="w-full h-full object-cover object-center grayscale-[10%] group-hover:grayscale-0 transition-all duration-300"
          />
        </div>
        <!-- Content Block -->
        <div class="flex flex-col items-start space-y-2">
          <div class="flex items-center space-x-2">
            <span class="text-lg md:text-xl font-serif font-bold text-[#b38f4f] group-hover:text-[#1c1c1a] transition-colors duration-300 leading-none shrink-0">03</span>
            <span class="w-4 h-[2px] bg-[#b38f4f] group-hover:bg-[#1c1c1a] transition-colors duration-300 shrink-0"></span>
            <h3 class="font-serif text-lg md:text-xl font-bold text-[#b38f4f] group-hover:text-[#1c1c1a] transition-colors duration-300 leading-none">
              Daily Clean-Up, Guaranteed
            </h3>
          </div>
          <p class="text-[#1c1c1a] font-sans text-base leading-relaxed font-medium">
            Dust barriers and thorough daily clean-ups are standard procedure.
          </p>
        </div>
      </div>

    </div>
  </div>
</section>
