---
---
<section id="testimonials" class="pb-12 md:pb-16 bg-[#fbfbfa] text-[#1c1c1a]">
  <div class="max-w-7xl mx-auto px-6">
    
    <!-- Section Header -->
    <div class="max-w-3xl flex flex-col space-y-3.5 mb-6">
      <span class="tracking-widest text-xs font-semibold text-[#b38f4f] uppercase block">
        Local Feedback
      </span>
      <h2 class="font-serif text-3xl sm:text-4xl md:text-5xl font-bold text-[#1c1c1a]">
        What Your Neighbors Are Saying
      </h2>
      <p class="text-[#1c1c1a] font-sans text-base leading-relaxed font-medium max-w-xl">
        We serve homeowners in Omaha, Bennington, and surrounding areas. Here is direct feedback from recent projects:
      </p>
    </div>

    <!-- Testimonials Layout Grid (Stacked on mobile, 2-columns on desktop) -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 lg:gap-10">
      
      <!-- Card 1 -->
      <div class="bg-white border border-stone-200/80 p-8 md:p-10 rounded-lg shadow-sm flex flex-col justify-between">
        <div class="flex flex-col space-y-3.5">
          <!-- Gold Quote Indicator (Accents Constraint) -->
          <div class="text-[#b38f4f]">
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 10.017-10.427V7.04c-3.76.37-5.485 2.08-5.733 5.448H24v8.512H14.017zM0 13.609C0 7.905 3.73 4 10.016 3.143V7.04C6.257 7.41 4.53 9.12 4.28 12.488H10.02v8.512H0v-7.391z" />
            </svg>
          </div>
          <!-- Quote -->
          <blockquote class="font-serif text-lg sm:text-xl text-[#1c1c1a] leading-relaxed italic">
            "The team at Heartland made the whole process easy. Our new kitchen is beautiful and actually works for our family."
          </blockquote>
        </div>
        <!-- Client Detail (Initials for Realism) -->
        <div class="mt-6 pt-4 border-t border-stone-100 flex items-center justify-between">
          <div>
            <span class="block font-sans text-sm font-bold text-[#1c1c1a]">D.S.</span>
            <span class="block font-sans text-[10px] uppercase tracking-wider text-[#b38f4f] font-semibold">Omaha Homeowner</span>
          </div>
        </div>
      </div>

      <!-- Card 2 -->
      <div class="bg-white border border-stone-200/80 p-8 md:p-10 rounded-lg shadow-sm flex flex-col justify-between">
        <div class="flex flex-col space-y-3.5">
          <!-- Gold Quote Indicator -->
          <div class="text-[#b38f4f]">
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 10.017-10.427V7.04c-3.76.37-5.485 2.08-5.733 5.448H24v8.512H14.017zM0 13.609C0 7.905 3.73 4 10.016 3.143V7.04C6.257 7.41 4.53 9.12 4.28 12.488H10.02v8.512H0v-7.391z" />
            </svg>
          </div>
          <!-- Quote -->
          <blockquote class="font-serif text-lg sm:text-xl text-[#1c1c1a] leading-relaxed italic">
            "The woodwork and attention to detail are incredible. They finished right on time."
          </blockquote>
        </div>
        <!-- Client Detail (Initials for Realism) -->
        <div class="mt-6 pt-4 border-t border-stone-100 flex items-center justify-between">
          <div>
            <span class="block font-sans text-sm font-bold text-[#1c1c1a]">M.T.</span>
            <span class="block font-sans text-[10px] uppercase tracking-wider text-[#b38f4f] font-semibold">Bennington Homeowner</span>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>
